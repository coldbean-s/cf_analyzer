# Database
DATABASE_URL=postgresql+asyncpg://postgres:dev@localhost:5432/postgres

# Auth
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# LLM defaults for users without their own keys
DEFAULT_LLM=claude
DEFAULT_LLM_KEY=

# Chrome
MAX_CHROME_INSTANCES=5
CF_HEADLESS=false

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:6010

# Admin (comma-separated GitHub user IDs)
ADMIN_GITHUB_IDS=
